# Copie este arquivo para .env.local e preencha os valores antes de rodar o projeto.
# O arquivo .env.local nunca deve ser commitado (já está no .gitignore via *.local).

# Senha do pesquisador. Usada na tela de login com o código "RESEARCHER".
# ATENÇÃO: variáveis VITE_* são embutidas no bundle JavaScript em tempo de build.
# Para segurança real, um backend com autenticação adequada é necessário.
VITE_RESEARCHER_PASSWORD=troque_esta_senha

# Senha do Gestor do Sistema. Usada na tela de login com o código "GESTOR".
# Dá acesso ao perfil ADMIN (maior privilégio): cadastrar pesquisadores, zerar dados, etc.
# Defina também nas variáveis de ambiente do Vercel (Settings → Environment Variables).
VITE_GESTOR_PASSWORD=troque_esta_senha_gestor
